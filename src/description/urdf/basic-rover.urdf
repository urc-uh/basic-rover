<?xml version="1.0"?>
<robot name="basic-rover">

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <link name="base_link"/>

  <link name="chassis">
    <visual>
      <geometry>
        <box size="0.75 0.5 0.15"/>
      </geometry>
      <origin xyz="-0.25 0 0.075"/>
    </visual>
  </link>
  <joint name="chassis_to_base_link" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
  </joint>

  <link name="wheel_front_left">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="wheel_front_left_to_chassis" type="continuous">
    <parent link="chassis"/>
    <child link="wheel_front_left"/>
    <axis xyz="0 0 1"/>
    <origin rpy="-1.57075 0 0" xyz="0 0.25 0.025"/>
  </joint>

  <link name="wheel_front_right">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="wheel_front_right_to_chassis" type="continuous">
    <parent link="chassis"/>
    <child link="wheel_front_right"/>
    <axis xyz="0 0 1"/>
    <origin rpy="1.57075 0 0" xyz="0 -0.25 0.025"/>
  </joint>

  <link name="wheel_rear_left">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="wheel_rear_left_to_chassis" type="continuous">
    <parent link="chassis"/>
    <child link="wheel_rear_left"/>
    <axis xyz="0 0 1"/>
    <origin rpy="-1.57075 0 0" xyz="-0.5 0.25 0.025"/>
  </joint>

  <link name="wheel_rear_right">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="wheel_rear_right_to_chassis" type="continuous">
    <parent link="chassis"/>
    <child link="wheel_rear_right"/>
    <axis xyz="0 0 1"/>
    <origin rpy="1.57075 0 0" xyz="-0.5 -0.25 0.025"/>
  </joint>

  <link name="camera_post">
    <visual>
      <geometry>
        <cylinder length="0.5" radius="0.01"/>
      </geometry>
      <origin xyz="0 0 0.25"/>
    </visual>
  </link>
  <joint name="camera_post_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="camera_post"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 -0.15 0.15"/>
  </joint>

  <link name="camera_mount">
    <visual>
      <geometry>
        <box size="0.05 0.225 0.05"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
    </visual>
  </link>
  <joint name="camera_mount_to_post" type="continuous">
    <parent link="camera_post"/>
    <child link="camera_mount"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.5"/>
  </joint>

  <link name="camera">
    <visual>
      <geometry>
        <box size="0.03 0.2 0.03"/>
      </geometry>
      <origin xyz="-0.015 0 0.015"/>
    </visual>
  </link>
  <joint name="camera_to_mount" type="revolute">
    <parent link="camera_mount"/>
    <child link="camera"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0.025 0 0" rpy="0 0.78540 0"/>
    <limit effort="10.0" lower="-0.78540" upper="0.78540" velocity="0.1"/>
  </joint>

  <link name="arm_base">
    <visual>
      <geometry>
        <cylinder length="0.075" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.0375"/>
    </visual>
  </link>
  <joint name="arm_base_to_chassis" type="continuous">
    <parent link="chassis"/>
    <child link="arm_base"/>
    <axis xyz="0 0 1"/>
    <origin xyz="-0.55 0 0.15"/>
  </joint>

  <link name="arm_joint_1">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="arm_joint_1_to_base" type="fixed">
    <parent link="arm_base"/>
    <child link="arm_joint_1"/>
    <origin xyz="0 0 0.075"/>
  </joint>

  <link name="arm_link_1.1">
    <visual>
      <geometry>
        <cylinder length="0.3" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.15"/>
    </visual>
  </link>
  <joint name="arm_link_1_to_base" type="revolute">
    <parent link="arm_joint_1"/>
    <child link="arm_link_1.1"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" upper="0.0" lower="-3.14159" velocity="0.1"/>
    <origin rpy="0 1.57075 0"/>
  </joint>

  <link name="arm_link_1.2">
    <visual>
      <geometry>
        <cylinder length="0.3" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.15"/>
    </visual>
  </link>
  <joint name="arm_link_1" type="continuous">
    <parent link="arm_link_1.1"/>
    <child link="arm_link_1.2"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.3"/>
  </joint>

  <link name="arm_joint_2">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="arm_joint_2_to_link_1" type="fixed">
    <parent link="arm_link_1.2"/>
    <child link="arm_joint_2"/>
    <origin xyz="0 0 0.3"/>
  </joint>

  <link name="arm_link_2.1">
    <visual>
      <geometry>
        <cylinder length="0.075" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.0375"/>
    </visual>
  </link>
  <joint name="arm_link_2_to_joint_2" type="revolute">
    <parent link="arm_joint_2"/>
    <child link="arm_link_2.1"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="0.0" upper="3.14159" velocity="0.1"/>
    <origin rpy="0 -1.57075 0"/>
  </joint>

  <link name="arm_link_2.2">
    <visual>
      <geometry>
        <cylinder length="0.075" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.0375"/>
    </visual>
  </link>
  <joint name="arm_link_2" type="continuous">
    <parent link="arm_link_2.1"/>
    <child link="arm_link_2.2"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.075"/>
  </joint>

  <link name="arm_joint_3">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="arm_joint_3_to_link_2" type="fixed">
    <parent link="arm_link_2.2"/>
    <child link="arm_joint_3"/>
    <origin xyz="0 0 0.075"/>
  </joint>

  <link name="arm_link_3">
    <visual>
      <geometry>
        <cylinder length="0.5" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.25"/>
    </visual>
  </link>
  <joint name="arm_link_3_to_joint_3" type="revolute">
    <parent link="arm_joint_3"/>
    <child link="arm_link_3"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="0.0" upper="3.14159" velocity="0.1"/>
    <origin rpy="0 -1.57075 0"/>
  </joint>

  <link name="hand">
    <visual>
      <geometry>
        <box size="0.175 0.125 0.06"/>
      </geometry>
      <material name="blue"/>
      <origin xyz="0.0875 0 0"/>
    </visual>
  </link>
  <joint name="wrist" type="continuous">
    <parent link="arm_link_3"/>
    <child link="hand"/>
    <axis xyz="1 0 0"/>
    <origin xyz="0 0 0.5" rpy="3.14159 -1.57075 0"/>
  </joint>

  <link name="gripper_left">
    <visual>
      <geometry>
        <box size="0.04 0.0075 0.03"/>
      </geometry>
      <origin xyz="0.02 -0.00375 0"/>
    </visual>
  </link>
  <joint name="gripper_left_to_hand" type="prismatic">
    <parent link="hand"/>
    <child link="gripper_left"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="0.0" upper="0.06" velocity="0.05"/>
    <origin xyz="0.175 0.06 0" rpy="3.14159 0 0"/>
  </joint>

  <link name="gripper_right">
    <visual>
      <geometry>
        <box size="0.04 0.0075 0.03"/>
      </geometry>
      <origin xyz="0.02 -0.00375 0"/>
    </visual>
  </link>
  <joint name="gripper_right_to_hand" type="prismatic">
    <parent link="hand"/>
    <child link="gripper_right"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="0.0" upper="0.06" velocity="0.05"/>
    <origin xyz="0.175 -0.06 0"/>
  </joint>

</robot>
